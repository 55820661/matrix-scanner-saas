# Django
DJANGO_SETTINGS_MODULE=scanner_platform.settings
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000
DJANGO_SECURE_PROXY_SSL_HEADER=false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false

# Database
DATABASE_URL=postgres://matrix_scanner:matrix_scanner@localhost:5432/matrix_scanner
POSTGRES_DB=matrix_scanner
POSTGRES_USER=matrix_scanner
POSTGRES_PASSWORD=matrix_scanner
POSTGRES_PORT=5432

# Security
TOKEN_HASH_SALT=change-me
FIELD_ENCRYPTION_KEY=change-me
BOOTSTRAP_CREDENTIAL_ENCRYPTION_KEY=change-me-to-a-long-random-bootstrap-key

# Runtime/API
PUBLIC_BASE_URL=http://localhost:8000
AGENT_REGISTRATION_TOKEN_TTL_MINUTES=60
AI_SAFE_CONTEXT_MAX_BYTES=65536

# Admin Live AI (disabled by default)
ADMIN_LIVE_AI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_CHATKIT_DOMAIN_KEY=
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_INPUT_TOKENS=12000
OPENAI_MAX_OUTPUT_TOKENS=1000
ADMIN_LIVE_AI_RATE_LIMIT_PER_HOUR=30

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change-me-to-a-random-webhook-secret
