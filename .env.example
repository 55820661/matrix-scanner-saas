# Django
DJANGO_SETTINGS_MODULE=scanner_platform.settings.local
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://matrix_scanner:matrix_scanner@localhost:5432/matrix_scanner

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Security
TOKEN_HASH_SALT=change-me
FIELD_ENCRYPTION_KEY=change-me

# Integrations - configure when the relevant sprint starts
TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=

# Runtime/API
PUBLIC_BASE_URL=http://localhost:8000
AGENT_REGISTRATION_TOKEN_TTL_MINUTES=60
